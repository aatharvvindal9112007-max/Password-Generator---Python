import secrets
import string
while True:
    print ("\t PASSWORD GENERATOR")
    UCL = input("Do you want Uppercase letters in (yes/no) : ").lower()
    LCL = input("Do you want Lowercase letters in (yes/no) : ").lower()
    NUM = input("Do you want Numbers in (yes/no) : ").lower()
    SYM = input("Do you want Symbols in (yes/no) : ").lower()
    LEN = int(input("Enter your password's Length : "))
    if LEN<=0:
        print ("Invalid length entered")
        continue
    pool = ""
    if UCL == 'yes':
        pool += string.ascii_uppercase
    if LCL == 'yes':
        pool += string.ascii_lowercase
    if NUM == 'yes':
        pool += string.digits
    if SYM == 'yes':
        pool += string.punctuation
    if pool == "":
      print ("No choice made")
    else:
      Password = ""
      for _ in range(LEN):
        Password += secrets.choice(pool)
      print ("your new Generated password is : " + Password )
    Continue = input("Do you want a new Password (yes/no) :").lower()
    if Continue != "yes":
     print ("Program is closed , click 'Run' for again ")
     break
